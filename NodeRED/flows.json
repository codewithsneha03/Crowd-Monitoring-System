    {
        "id": "9fcc9240ebcbbdb3",
        "type": "function",
        "z": "663f027b13260b79",
        "name": "Current Risk Function",
        "func": "let density = Number(msg.payload);\n\n// Store value based on topic\ncontext.set(msg.topic, density);\n\n// Read all zones\nlet zoneA = context.get(\"crowd/zoneA\") || 0;\nlet zoneB = context.get(\"crowd/zoneB\") || 0;\nlet zoneC = context.get(\"crowd/zoneC\") || 0;\nlet zoneD = context.get(\"crowd/zoneD\") || 0;\n\n// Find highest density\nlet maxDensity = Math.max(zoneA, zoneB, zoneC, zoneD);\n\nif (maxDensity > 800) {\n    msg.payload = \"🔴 HIGH\";\n}\nelse if (maxDensity > 500) {\n    msg.payload = \"🟡 MEDIUM\";\n}\nelse {\n    msg.payload = \"🟢 LOW\";\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 880,
        "y": 520,
